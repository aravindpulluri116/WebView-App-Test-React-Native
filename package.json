{
  "name": "subhchandra-webview",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "node ./node_modules/expo/bin/cli start",
    "android": "node ./node_modules/expo/bin/cli run:android",
    "prebuild": "node ./node_modules/expo/bin/cli prebuild --platform android",
    "build:apk": "eas build --platform android --profile preview",
    "build:aab": "eas build --platform android --profile production",
    "build:dev": "eas build --platform android --profile development",
    "submit:play": "eas submit --platform android --profile production --latest",
    "submit:internal": "eas submit --platform android --profile internal --latest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-community/netinfo": "11.5.2",
    "@react-native/virtualized-lists": "^0.83.6",
    "expo": "~55.0.0",
    "expo-build-properties": "~55.0.13",
    "expo-splash-screen": "~55.0.20",
    "expo-status-bar": "~55.0.6",
    "expo-web-browser": "~55.0.15",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-webview": "13.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "~19.2.10",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.2"
  },
  "private": true
}
